# importing

import pandas as pd
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.linear_model import LinearRegression
from sklearn.metrics import mean_squared_error, r2_score


# dataset
class GetData:
    def __init__(self):
        data = pd.read_csv("Dataset_PreviousGPA_to_Hours.csv")
        self.x = data.iloc[:, 1:-1].values
        self.y = data.iloc[:, -1].values
        self.x_train, self.x_test, self.y_train, self.y_test = self.train_data()
        self.sc = StandardScaler()
        self.feature_scaling()
        self.reg = LinearRegression()
        self.y_pred = self.training_dataset()

    # splitting into Training and Test set
    def train_data(self):
        return train_test_split(self.x, self.y, test_size=.2, random_state=0)

    def testing_data(self):
        print("x_train")
        print(self.x_train)
        print("x_test")
        print(self.x_test)
        print("y_train")
        print(self.y_train)
        print("y_test")
        print(self.y_test)

    # Feature Scaling

    def feature_scaling(self):
        self.x_train = self.sc.fit_transform(self.x_train)
        self.x_test = self.sc.transform(self.x_test)

    def feature_scaling_data(self):
        print(self.x_train)
        print(self.x_test)

# Training dataset with Linear Regression model

    def training_dataset(self):
        self.reg.fit(self.x_train, self.y_train)
# predicting Test set
        y_pred = self.reg.predict(self.x_test)
        return [round(p, 1) for p in y_pred]

    def training_dataset_data(self):
        print(self.y_test, self.y_pred)
        self.error_have()

    def error_have(self):
        mse = mean_squared_error(self.y_test, self.y_pred)
        r2 = r2_score(self.y_test, self.y_pred)
        print(f"Mean Squared Error: {mse:.2f}")
        print(f"R-squared: {r2:.2f}")


